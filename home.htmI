<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>العراق الأخضر - لوحة التحكم الرئيسية</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="style.css">
    <link rel="stylesheet" href="home.css">
</head>
<body>

    <div class="app-container">
        
        <header class="app-header">
            <div class="header-right">
                <div class="app-logo-small">
                    <svg viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M50 15C32 35 32 65 50 85C68 65 68 35 50 15Z" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M50 35C42 45 42 60 50 70" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                        <path d="M50 85V92" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/>
                    </svg>
                </div>
                <span class="app-name-tag">العراق الأخضر</span>
            </div>
            
            <div class="header-left">
                <button type="button" class="btn-notification" id="btnNotifications" aria-label="الإشعارات">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon-svg">
                        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path>
                        <path d="M13.73 21a2 2 0 0 1-3.46 0"></path>
                    </svg>
                    <span class="notification-badge" id="notifBadge"></span>
                </button>
                
                <div class="user-profile-wrapper" id="userProfileTrigger">
                    <span class="user-name" id="headerUserName">جاري التحميل...</span>
                    <div class="user-avatar" id="headerUserAvatar">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                            <circle cx="12" cy="7" r="4"></circle>
                        </svg>
                    </div>
                </div>
            </div>
        </header>

        <main class="app-main-content">
            
            <section class="stats-dashboard" aria-label="إحصائياتك البيئية">
                
                <div class="stat-card" id="statCardTrees">
                    <div class="stat-icon-wrapper icon-trees">🌱</div>
                    <div class="stat-info">
                        <span class="stat-label">الأشجار المزروعة</span>
                        <span class="stat-value" id="countTrees">0</span>
                    </div>
                </div>

                <div class="stat-card" id="statCardPoints">
                    <div class="stat-icon-wrapper icon-points">✨</div>
                    <div class="stat-info">
                        <span class="stat-label">مجموع النقاط</span>
                        <span class="stat-value" id="countPoints">0</span>
                    </div>
                </div>

                <div class="stat-card" id="statCardAchievements">
                    <div class="stat-icon-wrapper icon-achievements">🏆</div>
                    <div class="stat-info">
                        <span class="stat-label">الإنجازات المكتملة</span>
                        <span class="stat-value" id="countAchievements">0</span>
                    </div>
                </div>

            </section>

            <section class="services-grid" aria-label="أدوات المنصة">
                
                <div class="grid-card action-card" id="cardPlantTree">
                    <div class="grid-card-blur"></div>
                    <div class="grid-card-content">
                        <span class="grid-icon">🌱</span>
                        <h3 class="grid-title">زرع شجرة</h3>
                        <p class="grid-desc">سجل شجرة جديدة ووثق أثرك البيئي</p>
                    </div>
                </div>

                <div class="grid-card action-card" id="cardInteractiveMap">
                    <div class="grid-card-blur"></div>
                    <div class="grid-card-content">
                        <span class="grid-icon">🗺️</span>
                        <h3 class="grid-title">الخريطة</h3>
                        <p class="grid-desc">استكشف مساحات التشجير القريبة منك</p>
                    </div>
                </div>

                <div class="grid-card action-card" id="cardScanQR">
                    <div class="grid-card-blur"></div>
                    <div class="grid-card-content">
                        <span class="grid-icon">📷</span>
                        <h3 class="grid-title">مسح QR</h3>
                        <p class="grid-desc">امسح رمز الشجرة لتحديث بيانات سقيها</p>
                    </div>
                </div>

                <div class="grid-card action-card" id="cardUserAchievements">
                    <div class="grid-card-blur"></div>
                    <div class="grid-card-content">
                        <span class="grid-icon">🏆</span>
                        <h3 class="grid-title">الإنجازات</h3>
                        <p class="grid-desc">تابع تحدياتك وافتح أوسمة بيئية جديدة</p>
                    </div>
                </div>

                <div class="grid-card action-card" id="cardUserProfile">
                    <div class="grid-card-blur"></div>
                    <div class="grid-card-content">
                        <span class="grid-icon">👤</span>
                        <h3 class="grid-title">الملف الشخصي</h3>
                        <p class="grid-desc">إدارة بيانات حسابك وتتبع مستواك الحالي</p>
                    </div>
                </div>

                <div class="grid-card action-card" id="cardAppSettings">
                    <div class="grid-card-blur"></div>
                    <div class="grid-card-content">
                        <span class="grid-icon">⚙️</span>
                        <h3 class="grid-title">الإعدادات</h3>
                        <p class="grid-desc">تخصيص التطبيق، اللغات، وإشعارات النظام</p>
                    </div>
                </div>

            </section>

        </main>

        <nav class="bottom-navigation" aria-label="التنقل الرئيسي">
            
            <button type="button" class="nav-item active" id="navHomeBtn">
                <span class="nav-icon">🏠</span>
                <span class="nav-label">الرئيسية</span>
            </button>

            <button type="button" class="nav-item" id="navPlantBtn">
                <span class="nav-icon">🌱</span>
                <span class="nav-label">زرع</span>
            </button>

            <button type="button" class="nav-item" id="navMapBtn">
                <span class="nav-icon">🗺️</span>
                <span class="nav-label">الخريطة</span>
            </button>

            <button type="button" class="nav-item" id="navQRBtn">
                <span class="nav-icon">📷</span>
                <span class="nav-label">QR</span>
            </button>

            <button type="button" class="nav-item" id="navAccountBtn">
                <span class="nav-icon">👤</span>
                <span class="nav-label">الحساب</span>
            </button>

        </nav>

    </div>

    <script src="app.js"></script>
    <script src="home.js"></script>
</body>
</html>
